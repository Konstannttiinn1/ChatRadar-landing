---
const { site } = Astro.props;
---
<header class="header">
  <a class="brand" href="#top" aria-label="KLYXON home">
    <span class="brand-mark"><span></span></span>
    <span>KLYXON</span>
  </a>
  <nav class="nav" aria-label="Основная навигация">
    {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <div class="header-actions">
    <a class="login-link" href={site.supportUrl} target="_blank" rel="noreferrer">Связаться</a>
    <a class="button button-coral" href={site.botUrl} target="_blank" rel="noreferrer">Попробовать бесплатно</a>
  </div>
</header>
