---
const steps = [
  ['Подключаете чаты', 'Добавьте Telegram-чаты, где могут появляться клиенты, заявки, жалобы или важные запросы.'],
  ['Задаёте, что искать', 'Опишите ключевые слова, темы и правила: какие сообщения считать целевыми именно для вас.'],
  ['KLYXON следит в реальном времени', 'Новые сообщения сразу проходят первичный фильтр и проверку по смыслу через LLM.'],
  ['Получаете уведомление', 'Когда появляется подходящий запрос, бот присылает его в Telegram с чатом, автором, ссылкой и причиной срабатывания.'],
  ['Реагируете быстрее', 'Вы отвечаете человеку, пока запрос ещё горячий, а не находите его через поиск спустя несколько часов.']
];
---
<section class="section section-light" id="how-it-works">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker">Как это работает</p>
      <h2>От нового сообщения в чате до уведомления в Telegram</h2>
    </div>
    <div class="steps">
      {steps.map(([title, text], index) => (
        <article class="step-card">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
