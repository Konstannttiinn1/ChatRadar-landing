---
const steps = [
  ['Подключаете чаты', 'Добавьте нужные Telegram-чаты, где хотите отслеживать сообщения.'],
  ['Настраиваете логику', 'Задайте ключевые слова, темы, исключения и промпт для LLM.'],
  ['LLM анализирует', 'Каждое найденное сообщение проверяется по вашей бизнес-логике.'],
  ['Получаете важное', 'Релевантные уведомления приходят в Telegram без лишнего шума.'],
  ['Улучшаете фильтр', 'Корректируйте правила по реальным сообщениям и повышайте точность.']
];
---
<section class="section section-light" id="how-it-works">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker">Как это работает</p>
      <h2>От сообщения в чате до полезного уведомления</h2>
    </div>
    <div class="steps">
      {steps.map(([title, text], index) => (
        <article class="step-card">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
