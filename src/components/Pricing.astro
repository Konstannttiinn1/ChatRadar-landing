---
const { pricing, site } = Astro.props;
---
<section class="section section-light" id="pricing">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker">Тарифы</p>
      <h2>Начните с пробного периода</h2>
      <p class="muted">Оплаты на сайте нет: выбор тарифа ведёт в Telegram-бота.</p>
    </div>
    <div class="pricing-grid">
      {pricing.map((plan) => (
        <article class={`price-card ${plan.highlighted ? 'is-highlighted' : ''}`}>
          {plan.highlighted && <span class="badge">Популярный</span>}
          <h3>{plan.name}</h3>
          <div class="price"><strong>{plan.price}</strong><span>{plan.note}</span></div>
          <ul>
            {plan.features.map((feature) => <li>{feature}</li>)}
          </ul>
          <a class="button button-price" href={site.botUrl} target="_blank" rel="noreferrer">Выбрать</a>
        </article>
      ))}
    </div>
  </div>
</section>
