---
import HeroVisual from './HeroVisual.astro';

const { site, example } = Astro.props;
---
<section class="hero" id="top">
  <div class="hero-grid container">
    <div class="hero-copy">
      <p class="eyebrow">Фильтр чатов в Telegram</p>
      <h1>Видит только <span>важное.</span><br />Остальное — шум.</h1>
      <p class="hero-text">
        ChatRadar следит за выбранными Telegram-чатами, находит потенциально важные сообщения
        и проверяет их по вашей логике. В уведомления попадает только то, что действительно важно.
      </p>
      <div class="hero-buttons">
        <a class="button button-coral" href={site.botUrl} target="_blank" rel="noreferrer">Попробовать бесплатно</a>
        <a class="button button-ghost" href={site.supportUrl} target="_blank" rel="noreferrer">Связаться</a>
        <a class="button button-ghost subtle" href="#how-it-works">Как это работает</a>
      </div>
      <div class="hero-benefits">
        <span><b>LLM</b> на ваших правилах</span>
        <span><b>Меньше</b> шума</span>
        <span><b>Работает</b> 24/7</span>
        <span><b>Контроль:</b> только выбранные источники</span>
      </div>
    </div>

    <HeroVisual site={site} example={example} />
  </div>
</section>
