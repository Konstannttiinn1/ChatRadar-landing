---
// Current animated Hero visual.
// The previous static version is preserved in src/components/HeroVisualLegacy.astro.
---
<div class="hero-visual hero-visual-animated" aria-label="ChatRadar сканирует поток сообщений">
  <div class="hero-animation-card" data-chatradar-eye-wrap>
    <canvas data-chatradar-eye-canvas></canvas>
  </div>
</div>

<style>
  .hero-visual-animated {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-height: 585px;
  }

  .hero-animation-card {
    position: relative;
    width: min(780px, 100%);
    height: 585px;
    margin-left: auto;
    overflow: hidden;
    border-radius: 34px;
    background: #081311;
    box-shadow: 0 30px 100px rgba(0, 0, 0, .42);
    border: 1px solid rgba(255, 255, 255, .08);
    isolation: isolate;
  }

  .hero-animation-card canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 1180px) {
    .hero-visual-animated {
      justify-content: center;
      min-height: auto;
      margin-top: 12px;
    }

    .hero-animation-card {
      width: min(760px, 100%);
      height: 520px;
      margin: 0 auto;
    }
  }

  @media (max-width: 760px) {
    .hero-visual-animated {
      margin-top: 18px;
    }

    .hero-animation-card {
      width: 100%;
      height: auto;
      min-height: 0;
      aspect-ratio: 1.16 / 1;
      max-height: 340px;
      border-radius: 26px;
    }
  }

  @media (max-width: 400px) {
    .hero-animation-card {
      aspect-ratio: 1.08 / 1;
      max-height: 318px;
    }
  }
</style>

<style is:global>
  html,
  body {
    max-width: 100%;
    overflow-x: hidden;
  }

  .hero,
  .hero-grid,
  .hero-copy,
  .container {
    min-width: 0;
  }

  @media (max-width: 760px) {
    .header {
      gap: 12px;
      padding: 18px 18px;
    }

    .header-actions .button {
      display: none;
    }

    .hero {
      padding-top: 112px;
    }

    .hero h1 {
      max-width: 100%;
      font-size: clamp(38px, 12vw, 48px);
      line-height: 1.04;
      overflow-wrap: normal;
    }

    .hero h1 span {
      display: block;
    }

    .eyebrow {
      max-width: 100%;
      font-size: 11px;
      line-height: 1.45;
      letter-spacing: .07em;
    }

    .hero-text {
      max-width: 100%;
      font-size: 16px;
      line-height: 1.56;
    }

    .hero-buttons .button {
      width: 100%;
      max-width: 100%;
      min-height: 56px;
      padding: 0 16px;
      white-space: normal;
      text-align: center;
    }

    .hero-benefits {
      gap: 12px;
    }

    .hero-benefits span {
      padding: 14px 16px;
    }
  }
</style>

<script is:inline>
(() => {
  const canvases = document.querySelectorAll('[data-chatradar-eye-canvas]');

  canvases.forEach((cv) => {
    if (cv.dataset.ready === 'true') return;
    cv.dataset.ready = 'true';

    const wrap = cv.closest('[data-chatradar-eye-wrap]');
    const cx = cv.getContext('2d');
    if (!wrap || !cx) return;

    let W = 0;
    let H = 0;
    let CX = 0;
    let CY = 0;
    let EHW = 0;
    let EHH = 0;
    let RR = 0;
    let DR = 0;
    let dpr = 1;
    let sweep = 0;
    let leads = 0;
    let frame = 0;
    let rafId = 0;
    let isMobile = false;

    const T = {
      bgInner:'#0f1f1a', bgOuter:'#081311',
      lead:   {fill:'rgba(80,200,135,0.16)', border:'rgba(80,200,135,0.5)', av:'rgba(80,200,135,0.32)', dot:'rgba(165,235,190,0.92)', glow:'#50c887'},
      skip:   {fill:'rgba(225,130,95,0.14)', border:'rgba(225,130,95,0.42)', av:'rgba(225,130,95,0.26)', dot:'rgba(240,180,150,0.82)', glow:'#e1825f'},
      neutral:{fill:'rgba(100,130,135,0.09)',border:'rgba(100,130,135,0.2)', av:'rgba(100,130,135,0.15)', dot:'rgba(150,170,175,0.55)', glow:'#8a9ea0'},
      radar:'90,200,150', core:'170,240,200',
    };

    const TYPES = ['lead','lead','lead','lead','lead','skip','skip','skip','neutral','neutral'];
    const stars = [];

    function eyeH(tx){ return Math.sin(tx * Math.PI) * EHH; }

    function makeStars() {
      stars.length = 0;
      const amount = Math.max(isMobile ? 46 : 80, Math.round((W * H) / (isMobile ? 6200 : 4200)));
      for (let i = 0; i < amount; i++) {
        stars.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: Math.random() * 1.3 + 0.3,
          base: Math.random() * 0.4 + 0.1,
          tw: Math.random() * Math.PI * 2,
          twSpeed: 0.01 + Math.random() * 0.02,
        });
      }
    }

    class Msg {
      constructor(){ this.reset(); this.tx = Math.random(); }
      reset(st = 0){
        this.tx = -0.05;
        this.lane = Math.random() * 2 - 1;
        this.speed = 0.0007 + Math.random() * 0.0004;
        this.type = TYPES[Math.floor(Math.random() * TYPES.length)];
        this.bob = Math.random() * Math.PI * 2;
        this.bobAmp = 4 + Math.random() * 5;
        this.size = 0.85 + Math.random() * 0.3;
        this.stagger = st;
        this.detected = false;
        this.flash = 0;
      }
      pos(){
        const x = CX - EHW + this.tx * (EHW * 2);
        const y = CY + this.lane * eyeH(this.tx) + Math.sin(this.bob) * this.bobAmp;
        return { x, y };
      }
    }

    const msgs = Array.from({ length: 50 }, () => new Msg());

    function roundRect(ctx, x, y, w, h, r) {
      if (typeof ctx.roundRect === 'function') {
        ctx.roundRect(x, y, w, h, r);
        return;
      }
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
    }

    function resize() {
      const rect = wrap.getBoundingClientRect();
      W = Math.max(280, Math.floor(rect.width));
      H = Math.max(260, Math.floor(rect.height));
      isMobile = W < 540;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      cv.width = Math.floor(W * dpr);
      cv.height = Math.floor(H * dpr);
      cv.style.width = W + 'px';
      cv.style.height = H + 'px';
      cx.setTransform(dpr, 0, 0, dpr, 0, 0);

      CX = isMobile ? W * 0.5 : W / 2;
      CY = isMobile ? H * 0.48 : H / 2;
      EHW = Math.min(W * (isMobile ? 0.36 : 0.44), 600);
      EHH = Math.min(H * (isMobile ? 0.23 : 0.30), 185);
      RR = Math.min(W, H) * (isMobile ? 0.18 : 0.24);
      DR = RR * 1.05;
      makeStars();
    }

    function drawMsg(m){
      const {x, y} = m.pos();
      const ef = Math.sin(Math.max(0, Math.min(1, m.tx)) * Math.PI);
      const alpha = Math.max(0, Math.min(1, ef * 1.4));
      if (alpha <= 0.02) return;
      const c = T[m.type];
      const scale = m.size * (0.6 + ef * 0.4) * (isMobile ? 0.72 : 1);
      cx.save();
      cx.globalAlpha = alpha;
      cx.translate(x, y);
      cx.scale(scale, scale);

      const PW = 54, PH = 21, R = 7;
      const px = -PW / 2, py = -PH / 2;
      const fl = m.flash > 0;
      if (fl) { cx.shadowColor = c.glow; cx.shadowBlur = 15 * m.flash; }

      cx.beginPath();
      roundRect(cx, px, py, PW, PH, R);
      cx.fillStyle = c.fill;
      cx.fill();
      cx.strokeStyle = fl ? c.glow : c.border;
      cx.lineWidth = fl ? 1.5 : 1;
      cx.stroke();
      cx.shadowBlur = 0;

      cx.beginPath();
      cx.moveTo(px + 8, py + PH);
      cx.lineTo(px + 4, py + PH + 5);
      cx.lineTo(px + 15, py + PH);
      cx.closePath();
      cx.fillStyle = c.fill;
      cx.fill();
      cx.strokeStyle = fl ? c.glow : c.border;
      cx.lineWidth = fl ? 1.4 : 1;
      cx.stroke();
      cx.beginPath();
      cx.moveTo(px + 5, py + PH - 0.5);
      cx.lineTo(px + 15, py + PH - 0.5);
      cx.strokeStyle = c.fill;
      cx.lineWidth = 2;
      cx.stroke();

      const dotY = py + PH / 2;
      cx.beginPath();
      cx.arc(px + 9, dotY, 4.5, 0, Math.PI * 2);
      cx.fillStyle = c.av;
      cx.fill();

      cx.fillStyle = c.dot;
      [px + 18, px + 27, px + 36].forEach((dx) => {
        cx.beginPath();
        cx.arc(dx, dotY, 1.5, 0, Math.PI * 2);
        cx.fill();
      });

      cx.restore();
    }

    function drawHud(){
      const pad = isMobile ? 18 : 28;
      cx.fillStyle = `rgba(${T.radar},0.8)`;
      cx.font = `${isMobile ? '700 12px' : '700 13px'} Inter, system-ui, sans-serif`;
      cx.textAlign = 'left';
      cx.textBaseline = 'top';
      cx.fillText('ChatRadar', pad, isMobile ? 20 : 26);
      cx.fillStyle = `rgba(${T.radar},0.32)`;
      cx.font = `${isMobile ? '500 9px' : '500 10px'} Inter, system-ui, sans-serif`;
      cx.fillText('сканирует поток сообщений', pad, isMobile ? 38 : 44);

      cx.fillStyle = `rgba(${T.radar},0.9)`;
      cx.font = `${isMobile ? '700 24px' : '700 34px'} Inter, system-ui, sans-serif`;
      cx.textAlign = 'right';
      cx.textBaseline = 'top';
      cx.fillText(leads, W - pad, isMobile ? 18 : 24);
      cx.fillStyle = `rgba(${T.radar},0.3)`;
      cx.font = `${isMobile ? '600 8px' : '600 9px'} Inter, system-ui, sans-serif`;
      cx.fillText('ЛИДОВ НАЙДЕНО', W - pad, isMobile ? 48 : 62);

      [
        ['rgba(80,200,135,0.8)','● релевантный лид'],
        ['rgba(225,130,95,0.75)','● нерелевантное'],
        ['rgba(100,130,135,0.5)','● нейтральное'],
      ].forEach(([col, txt], i) => {
        cx.fillStyle = col;
        cx.font = `${isMobile ? '500 9px' : '500 10px'} Inter, system-ui, sans-serif`;
        cx.textAlign = 'left';
        cx.textBaseline = 'bottom';
        cx.fillText(txt, pad, H - (isMobile ? 16 : 20) - i * (isMobile ? 16 : 18));
      });
    }

    function loop(){
      frame++;
      const bg = cx.createRadialGradient(CX, CY, 0, CX, CY, Math.max(W, H) * 0.6);
      bg.addColorStop(0, T.bgInner);
      bg.addColorStop(1, T.bgOuter);
      cx.fillStyle = bg;
      cx.fillRect(0, 0, W, H);

      stars.forEach((s) => {
        s.tw += s.twSpeed;
        const a = s.base + Math.sin(s.tw) * s.base * 0.7;
        cx.globalAlpha = Math.max(0, a);
        cx.beginPath();
        cx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        cx.fillStyle = 'rgba(180,220,200,1)';
        cx.fill();
      });
      cx.globalAlpha = 1;

      sweep += 0.006;

      cx.save();
      const zg = cx.createRadialGradient(CX, CY, 0, CX, CY, RR * 1.6);
      zg.addColorStop(0, 'rgba(45,75,62,0.3)');
      zg.addColorStop(0.6, 'rgba(30,50,42,0.15)');
      zg.addColorStop(1, 'rgba(20,30,28,0)');
      cx.fillStyle = zg;
      cx.beginPath();
      cx.arc(CX, CY, RR * 1.6, 0, Math.PI * 2);
      cx.fill();
      [0.38,0.62,0.88,1.15,1.45].forEach((f, i) => {
        cx.beginPath();
        cx.arc(CX, CY, RR * f, 0, Math.PI * 2);
        cx.strokeStyle = `rgba(${T.radar},${0.1 - i * 0.015})`;
        cx.lineWidth = 1;
        cx.stroke();
      });
      cx.beginPath();
      cx.moveTo(CX - RR * 1.45, CY);
      cx.lineTo(CX + RR * 1.45, CY);
      cx.moveTo(CX, CY - RR * 1.45);
      cx.lineTo(CX, CY + RR * 1.45);
      cx.strokeStyle = `rgba(${T.radar},0.05)`;
      cx.lineWidth = 0.6;
      cx.stroke();
      cx.restore();

      msgs.forEach((m) => {
        if (m.stagger > 0) { m.stagger--; return; }
        m.tx += m.speed;
        m.bob += 0.02;
        if (m.flash > 0) m.flash -= 0.04;
        const {x, y} = m.pos();
        const dist = Math.sqrt((x - CX) ** 2 + (y - CY) ** 2);
        if (!m.detected && dist < DR) { m.detected = true; m.flash = 1; if (m.type === 'lead') leads++; }
        if (m.detected && dist > DR && x > CX) m.detected = false;
        if (m.tx > 1.05) m.reset(Math.floor(Math.random() * 30));
        drawMsg(m);
      });

      cx.save();
      cx.beginPath();
      cx.moveTo(CX, CY);
      cx.arc(CX, CY, RR * 1.45, sweep, sweep + 0.4);
      cx.closePath();
      const sg = cx.createRadialGradient(CX, CY, 0, CX, CY, RR * 1.45);
      sg.addColorStop(0, `rgba(${T.radar},0.13)`);
      sg.addColorStop(1, `rgba(${T.radar},0)`);
      cx.fillStyle = sg;
      cx.fill();
      cx.beginPath();
      cx.moveTo(CX, CY);
      cx.lineTo(CX + Math.cos(sweep) * RR * 1.45, CY + Math.sin(sweep) * RR * 1.45);
      cx.strokeStyle = `rgba(${T.radar},0.4)`;
      cx.lineWidth = 1.3;
      cx.stroke();
      cx.restore();

      const p = Math.sin(frame * 0.04) * 0.25 + 0.75;
      cx.save();
      const cg = cx.createRadialGradient(CX, CY, 0, CX, CY, isMobile ? 28 : 36);
      cg.addColorStop(0, `rgba(${T.core},${0.5 * p})`);
      cg.addColorStop(0.4, `rgba(${T.core},${0.2 * p})`);
      cg.addColorStop(1, `rgba(${T.core},0)`);
      cx.fillStyle = cg;
      cx.beginPath();
      cx.arc(CX, CY, isMobile ? 28 : 36, 0, Math.PI * 2);
      cx.fill();
      cx.shadowColor = `rgb(${T.core})`;
      cx.shadowBlur = (isMobile ? 14 : 18) * p;
      cx.beginPath();
      cx.arc(CX, CY, isMobile ? 8 : 10, 0, Math.PI * 2);
      cx.fillStyle = `rgba(${T.core},0.95)`;
      cx.fill();
      cx.shadowBlur = 0;
      cx.beginPath();
      cx.arc(CX, CY, isMobile ? 3.5 : 4.5, 0, Math.PI * 2);
      cx.fillStyle = 'rgba(15,40,32,0.6)';
      cx.fill();
      cx.restore();

      drawHud();
      rafId = requestAnimationFrame(loop);
    }

    resize();
    const observer = new ResizeObserver(() => resize());
    observer.observe(wrap);
    rafId = requestAnimationFrame(loop);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(rafId);
      } else {
        rafId = requestAnimationFrame(loop);
      }
    });
  });
})();
</script>
