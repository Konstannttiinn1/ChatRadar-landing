---
const { faq } = Astro.props;
---
<section class="section section-light" id="faq">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker">FAQ</p>
      <h2>Вопросы и ответы</h2>
      <p class="muted trust-note">KLYXON не предназначен для спама и скрытого массового сбора данных. Сервис работает с чатами, к которым у пользователя есть доступ, и помогает находить релевантные сообщения по заданным правилам.</p>
    </div>
    <div class="faq-grid">
      {faq.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-note {
    max-width: 760px;
    margin: 14px auto 0;
    font-size: 15px;
  }
</style>
